{
  "expo": {
    "name": "ALON",
    "slug": "ALON",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "alon",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1F4A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trythat.alon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1F4A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.trythat.alon"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6828e523-8cb8-433a-a1d4-b923ccac6c41"
      }
    },
    "owner": "abhinav-raj",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6828e523-8cb8-433a-a1d4-b923ccac6c41"
    }
  }
}
